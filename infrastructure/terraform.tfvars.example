aws_region   = "us-east-1"
project_name = "expense-tracker"
environment  = "production"

vpc_cidr           = "10.0.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b"]

# EKS — lightweight, autoscales between 1 and 3 nodes
eks_cluster_version    = "1.30"
eks_node_instance_type = "t3.small"
eks_node_min_size      = 1
eks_node_max_size      = 3
eks_node_desired_size  = 2

# RDS — smallest burstable instance, upgrade to db.t3.small if needed
rds_instance_class    = "db.t3.micro"
rds_db_name           = "expense_tracker"
rds_username          = "app"
rds_allocated_storage = 20

# Set the DB password via this file (excluded from git) or the environment:
#   export TF_VAR_rds_db_password="your-strong-password"
rds_db_password = "REPLACE_WITH_STRONG_PASSWORD"
